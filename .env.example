# Stripe Configuration
# Copy this file to .env.local and fill in your actual keys

# Stripe publishable key (starts with pk_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe price IDs for subscription plans
VITE_STRIPE_PRICE_MONTHLY=price_your_monthly_price_id
VITE_STRIPE_PRICE_YEARLY=price_your_yearly_price_id

# Stripe secret key (server-side only, starts with sk_)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# API Server Configuration
API_PORT=3001
FRONTEND_URL=http://localhost:5173

# API URL for frontend to call backend
VITE_API_URL=http://localhost:3001

# Google Calendar Configuration
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
GOOGLE_IMPERSONATE_EMAIL=your-email@domain.com
GOOGLE_CALENDAR_NAME=Work
